# Global fallback key applied to all explorers that do not have a network override
EXPLORER_API_KEY=

# Network-specific explorer API keys
EXPLORER_API_KEY_MAINNET=
EXPLORER_API_KEY_SEPOLIA=
EXPLORER_API_KEY_BASE=
EXPLORER_API_KEY_ARBITRUM=
EXPLORER_API_KEY_OPTIMISM=
EXPLORER_API_KEY_POLYGON=
EXPLORER_API_KEY_AVALANCHE=
EXPLORER_API_KEY_BSC=
EXPLORER_API_KEY_LINEA=
EXPLORER_API_KEY_SOLANA_MAINNET=
EXPLORER_API_KEY_SOLANA_DEVNET=

# Vite-prefixed variants for the Chrome extension build
VITE_EXPLORER_API_KEY=
VITE_EXPLORER_API_KEY_MAINNET=
VITE_EXPLORER_API_KEY_SEPOLIA=
VITE_EXPLORER_API_KEY_BASE=
VITE_EXPLORER_API_KEY_ARBITRUM=
VITE_EXPLORER_API_KEY_OPTIMISM=
VITE_EXPLORER_API_KEY_POLYGON=
VITE_EXPLORER_API_KEY_AVALANCHE=
VITE_EXPLORER_API_KEY_BSC=
VITE_EXPLORER_API_KEY_LINEA=
VITE_EXPLORER_API_KEY_SOLANA_MAINNET=
VITE_EXPLORER_API_KEY_SOLANA_DEVNET=

# Alchemy API key (https://dashboard.alchemy.com/)
# One key covers EVM RPC (eth, base, polygon, arb, opt, sepolia, etc.) and Solana RPC.
# Used in config.json via the ${ALCHEMY_API_KEY} placeholder.
# CLI reads ALCHEMY_API_KEY; extension build reads VITE_ALCHEMY_API_KEY; mobile reads EXPO_PUBLIC_ALCHEMY_API_KEY.
ALCHEMY_API_KEY=
VITE_ALCHEMY_API_KEY=
EXPO_PUBLIC_ALCHEMY_API_KEY=

# Helius RPC API key for Solana (https://dev.helius.xyz/) — legacy, superseded by Alchemy.
# Still read by config-utils for backward compatibility with older config.json files.
HELIUS_API_KEY=
VITE_HELIUS_API_KEY=


# CoinGecko API key (demo/pro)
# CLI + mobile use COINGECKO_API_KEY; extension build uses VITE_COINGECKO_API_KEY
COINGECKO_API_KEY=
VITE_COINGECKO_API_KEY=

TONCENTER_API_KEY=
TONCENTER_API_KEY_TON_MAINNET=
TONCENTER_API_KEY_TON_TESTNET=
VITE_TONCENTER_API_KEY=
VITE_TONCENTER_API_KEY_TON_MAINNET=
VITE_TONCENTER_API_KEY_TON_TESTNET=
