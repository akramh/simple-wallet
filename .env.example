# -----------------------------------------------------------------------------
# Quick start
# -----------------------------------------------------------------------------
# Easiest path: just run the app — the first-run flow prompts for an Alchemy
# key and the CLI writes it to this file for you (extension/mobile store it
# in their own runtime storage).
#
# To configure manually instead:
# 1. Copy this file:            cp .env.example .env
# 2. Get a free Alchemy key:    https://dashboard.alchemy.com/
# 3. Set ALCHEMY_API_KEY below. That single key covers EVM + Solana RPC,
#    transaction history, prices, and portfolio data — enough to run the wallet.
#
# Everything else in this file is OPTIONAL: keys for non-Alchemy chains
# (TON) and for higher rate limits (CoinGecko, Etherscan fallback). The wallet
# runs without them, using public fallbacks.
#
# For the extension build, set VITE_ALCHEMY_API_KEY; for mobile, set
# EXPO_PUBLIC_ALCHEMY_API_KEY (see the Alchemy section below).
#
# -----------------------------------------------------------------------------
# Maintainers only: this project's secrets are also managed in Doppler
# (project: simple-wallet, config: dev). If you have access, you can run
# `npm run sync-secrets` instead of editing this file by hand. External
# contributors should ignore Doppler and use the copy-and-edit flow above.
# -----------------------------------------------------------------------------

# =============================================================================
# REQUIRED: Alchemy API key (https://dashboard.alchemy.com/)
# =============================================================================
# One key covers EVM RPC (eth, base, polygon, arb, opt, sepolia, avalanche,
# bsc, linea), Solana RPC, the Transfers API (tx history), the Prices API, and
# the Portfolio Data API. The hostname selects the chain — there is no
# per-chain Alchemy key. Used in config.json via the ${ALCHEMY_API_KEY}
# placeholder. CLI reads ALCHEMY_API_KEY; the extension build reads
# VITE_ALCHEMY_API_KEY; mobile reads EXPO_PUBLIC_ALCHEMY_API_KEY.
ALCHEMY_API_KEY=
VITE_ALCHEMY_API_KEY=
EXPO_PUBLIC_ALCHEMY_API_KEY=

# =============================================================================
# OPTIONAL: everything below. The wallet runs on public fallbacks without them.
# =============================================================================

# Global fallback key applied to all explorers that do not have a network override
EXPLORER_API_KEY=

# Network-specific explorer API keys
EXPLORER_API_KEY_MAINNET=
EXPLORER_API_KEY_SEPOLIA=
EXPLORER_API_KEY_BASE=
EXPLORER_API_KEY_ARBITRUM=
EXPLORER_API_KEY_OPTIMISM=
EXPLORER_API_KEY_POLYGON=
EXPLORER_API_KEY_AVALANCHE=
EXPLORER_API_KEY_BSC=
EXPLORER_API_KEY_LINEA=
EXPLORER_API_KEY_SOLANA_MAINNET=
EXPLORER_API_KEY_SOLANA_DEVNET=

# Vite-prefixed variants for the Chrome extension build
VITE_EXPLORER_API_KEY=
VITE_EXPLORER_API_KEY_MAINNET=
VITE_EXPLORER_API_KEY_SEPOLIA=
VITE_EXPLORER_API_KEY_BASE=
VITE_EXPLORER_API_KEY_ARBITRUM=
VITE_EXPLORER_API_KEY_OPTIMISM=
VITE_EXPLORER_API_KEY_POLYGON=
VITE_EXPLORER_API_KEY_AVALANCHE=
VITE_EXPLORER_API_KEY_BSC=
VITE_EXPLORER_API_KEY_LINEA=
VITE_EXPLORER_API_KEY_SOLANA_MAINNET=
VITE_EXPLORER_API_KEY_SOLANA_DEVNET=

# Helius RPC API key for Solana (https://dev.helius.xyz/) — legacy, superseded by Alchemy.
# Still read by config-utils for backward compatibility with older config.json files.
HELIUS_API_KEY=
VITE_HELIUS_API_KEY=

# CoinGecko API key (demo/pro) — optional; enables the Pro host and higher rate limits.
# CLI + mobile use COINGECKO_API_KEY; extension build uses VITE_COINGECKO_API_KEY
COINGECKO_API_KEY=
VITE_COINGECKO_API_KEY=

TONCENTER_API_KEY=
TONCENTER_API_KEY_TON_MAINNET=
TONCENTER_API_KEY_TON_TESTNET=
VITE_TONCENTER_API_KEY=
VITE_TONCENTER_API_KEY_TON_MAINNET=
VITE_TONCENTER_API_KEY_TON_TESTNET=
