{
  "name": "simple-wallet",
  "version": "1.0.0",
  "description": "Multi-chain wallet (EVM, Bitcoin, Solana, XRP, TON) built on Alchemy — a single API key powers RPC, transaction history, prices, and portfolio data across a CLI, a Chrome extension, and a mobile app.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk.js",
    "./sdk-browser": "./dist/sdk-browser.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "gen:manifest-csp": "tsx scripts/generate-manifest-csp.ts",
    "check:manifest-csp": "tsx scripts/generate-manifest-csp.ts --check",
    "prebuild:extension": "npm run gen:manifest-csp",
    "build:extension": "vite build --config vite.config.extension.ts",
    "watch:extension": "vite build --config vite.config.extension.ts --watch",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test tests/*.test.js",
    "type-check": "tsc --noEmit",
    "type-check:extension": "tsc --noEmit -p extension",
    "sync-secrets": "tsx scripts/sync-secrets.ts"
  },
  "keywords": [
    "alchemy",
    "wallet",
    "crypto",
    "multi-chain",
    "ethereum",
    "bitcoin",
    "solana",
    "xrp",
    "ton",
    "chrome-extension",
    "react-native",
    "web3"
  ],
  "author": "akramh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akramh/simple-wallet.git"
  },
  "homepage": "https://github.com/akramh/simple-wallet#readme",
  "bugs": {
    "url": "https://github.com/akramh/simple-wallet/issues"
  },
  "dependencies": {
    "@noble/secp256k1": "^3.0.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/postcss": "^4.1.17",
    "@ton/core": "^0.57.0",
    "@ton/ton": "^13.0.0",
    "asmcrypto.js": "^2.3.2",
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.0",
    "buffer": "^6.0.3",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "ecpair": "^3.0.0",
    "ed25519-hd-key": "^1.3.0",
    "ethereum-blockies-base64": "^1.0.2",
    "ethers": "^6.9.0",
    "inquirer": "^9.2.12",
    "lucide-react": "^1.8.0",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "tiny-secp256k1": "^2.2.4",
    "tweetnacl": "^1.0.3",
    "xrpl": "^4.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
