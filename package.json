{
  "name": "simple-crypto-wallet",
  "version": "1.0.0",
  "description": "A simple Ethereum wallet with testnet/mainnet support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ethereum",
    "wallet",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "ethers": "^6.9.0",
    "inquirer": "^9.2.12",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
