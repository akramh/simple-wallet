{
  "name": "simple-crypto-wallet",
  "version": "1.0.0",
  "description": "A simple Ethereum wallet with testnet/mainnet support",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk.js",
    "./sdk-browser": "./dist/sdk-browser.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:extension": "vite build --config vite.config.extension.ts",
    "watch:extension": "vite build --config vite.config.extension.ts --watch",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ethereum",
    "wallet",
    "crypto"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@noble/secp256k1": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.17",
    "asmcrypto.js": "^2.3.2",
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "ecpair": "^3.0.0",
    "ethers": "^6.9.0",
    "inquirer": "^9.2.12",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "tiny-secp256k1": "^2.2.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0"
  }
}
