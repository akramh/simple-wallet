{
  "expo": {
    "name": "Simple Wallet",
    "slug": "simple-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "simplewallet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6D4AFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./assets/images/icon-ios.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.simplewallet.app",
      "buildNumber": "1.0.15",
      "infoPlist": {
        "NSCameraUsageDescription": "Simple Wallet needs camera access to scan QR codes for receiving crypto payments.",
        "NSFaceIDUsageDescription": "Simple Wallet uses Face ID to securely unlock your wallet.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#101828"
      },
      "package": "com.simplewallet.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Simple Wallet needs camera access to scan QR codes."
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#9333ea"
        }
      ],
      "expo-background-fetch",
      "./plugins/withNetworkSecurity"
    ],

    "extra": {
      "router": {
        "asyncRoutes": false
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
