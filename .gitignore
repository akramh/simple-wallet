node_modules/
wallet.json
wallets.json
wallets.json.backup
wallets.json.tmp
wallet-key
backup-*.json
# Per-user custom token overlay, created at runtime by WalletAppService.
# The shipped registry is tokens.json; this file is per-user state.
tokens-user.json
*.log
# All .env variants hold live keys — only the template is tracked.
.env
.env.*
!.env.example
.doppler/
.claude/
# CLI user-state (current network, showTestnets toggle). Persisted here
# rather than config.json so the shipped template is never mutated with
# substituted env values (would leak the Alchemy key into git).
config.local.json

# TypeScript build output
dist/
dist-extension/
*.tsbuildinfo
.github/
.npm-cache/
temp/
# -----------------------------------------------------------------------------
# Documentation location policy
# -----------------------------------------------------------------------------
# Keep canonical project documentation under docs/. Root README, LICENSE, and
# tool-specific instruction files stay at the repository root.
**/*PLAN*.md
**/*.plan.md
!docs/
!docs/**
